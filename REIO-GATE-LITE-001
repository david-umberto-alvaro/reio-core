-- REIO-GATE-LITE-001 : Implémentation basse consommation de la porte REIO
-- Optimisée pour l'IoT / Conforme au Standard REIO-RFC-003 / Licence GNU GPLv3
library IEEE;
use IEEE.STD_LOGIC_1164.ALL;

entity REIO_Gate_Lite is
    Port ( 
        Ligne_A : in  STD_LOGIC;  -- Signal d'entrée A
        Ligne_B : in  STD_LOGIC;  -- Signal d'entrée B
        Sortie_S : out STD_LOGIC; -- Canal d'Exécution Nominal
        Ligne_Q  : out STD_LOGIC  -- Canal de Quarantaine Énergétique
    );
end REIO_Gate_Lite;

architecture Behavioral of REIO_Gate_Lite is
begin
    -- Économie de transistors : Utilisation d'équations booléennes directes 
    -- sans processus séquentiel lourd (Zéro consommation au repos)
    
    Sortie_S <= Ligne_A and Ligne_B; -- Traitement nominal direct
    Ligne_Q  <= Ligne_A xor Ligne_B; -- Activation de la quarantaine uniquement en cas de divergence (1,0 ou 0,1)
    
end Behavioral;
